params {
    // Unique per-invocation id (timestamp), computed once when this config is
    // parsed and shared by any profile that needs a collision-free run directory.
    // The oscer profile uses it to give each run its own work dir and results dir
    // on scratch. Override with --run_id to pin a name.
    run_id = new java.text.SimpleDateFormat('yyyyMMdd_HHmmss').format(new Date())

    // Root dir for a profile's run outputs. Each run lands in one self-contained
    // directory — <out_root>/<run_id>/{work,results} — so a whole run is a single
    // unit to size (`du -sh`) or prune (`rm -rf`). The shared Apptainer cache is a
    // sibling of the run dirs (<out_root>/apptainer_cache), never nested under a
    // run_id. Set per-profile below; interpolated into workDir/outdir/cacheDir.
    out_root_local = "${System.getenv('HOME')}/sammy_r21_out"
    out_root_oscer = "/scratch/${System.getenv('USER')}/sammy_r21_out"

    // Required: pipeline step to run. Pass via --step.
    // Valid values: create_adata
    step = null

    // Required: path to a samplesheet CSV (columns vary by step)
    samplesheet = null

    // Output directory for published results
    outdir = 'results'
}

profiles {
    local {
        // Keep the work dir and published results out of the repo (runs are usually
        // launched from the repo root) and in a dedicated home-dir location. Each run
        // gets one self-contained directory — sammy_r21_out/<run_id>/{work,results} —
        // so a whole run is a single unit to size (`du -sh`) or prune (`rm -rf`).
        // Override with --outdir / --run_id if needed.
        workDir = "${params.out_root_local}/${params.run_id}/work"

        // Delete the work dir once the whole run completes successfully, so only the
        // (hardlinked) results survive — each output then lives exactly once. Nextflow
        // scopes this to success: a failed run keeps its work dir, so resume-after-
        // failure (bump resources, skip finished samples) still works. It only forfeits
        // resume-FROM-success, which this single-process-per-step pipeline rarely uses.
        cleanup = true

        // Constrain local runs to avoid host OOM/restarts on laptop-class machines.
        params {
            samplesheet = "${launchDir}/assets/samplesheet.csv"
            outdir      = "${params.out_root_local}/${params.run_id}/results"
        }
        process {
            executor      = 'local'
            container     = 'babiddy755/python_spatial:1.2.0'
            cpus          = 8
            memory        = '16 GB'
            maxForks      = 1
            errorStrategy = 'finish'
        }
        apptainer {
            enabled    = true
            runOptions = '--writable-tmpfs'
            // Cache the pulled image in a stable, run-independent location — a sibling
            // of the per-run dirs, never nested under a run_id. Without this, cacheDir
            // defaults to <workDir>/singularity — and since workDir now carries a
            // per-run id, every run would re-pull/re-convert the image.
            cacheDir   = "${params.out_root_local}/apptainer_cache"
        }
    }

    oscer {
        // Keep both the Nextflow work dir and published results on scratch — the
        // large, compute-node-accessible filesystem on OSCER (home is small and not
        // meant for pipeline I/O). Each run gets one self-contained directory —
        // sammy_r21_out/<run_id>/{work,results} — so concurrent runs don't collide and
        // a whole run is a single unit to size (`du -sh`) or prune (`rm -rf`). Keeping
        // work and results under the same root also keeps them on one filesystem, which
        // the modules' hardlink publishing relies on. Override with --outdir if needed.
        workDir = "${params.out_root_oscer}/${params.run_id}/work"

        // Delete the work dir once the whole run completes successfully, so only the
        // (hardlinked) results survive on scratch — the main lever against quota
        // pressure here. Success-scoped: a failed run keeps its work dir for resume-
        // after-failure.
        cleanup = true

        params {
            outdir = "${params.out_root_oscer}/${params.run_id}/results"
        }

        process {
            executor      = 'slurm'
            queue         = 'normal'
            container     = 'babiddy755/python_spatial:1.2.0'
            // The `normal` partition allows 48 h / ~250 GB / 64 cores per node.
            // create_adata is a single read + QC pass over one Cell Ranger matrix,
            // so it is far below these caps; the retry ladder is headroom, not need.
            cpus          = 16
            memory        = { 48.GB * task.attempt }
            time          = { 4.h + (task.attempt - 1) * 4.h }
            errorStrategy = 'retry'
            maxRetries    = 3
        }
        apptainer {
            enabled     = true
            runOptions  = '--writable-tmpfs'
            // Cache the pulled image in a stable, run-independent scratch location — a
            // sibling of the per-run dirs, never nested under a run_id. Without this,
            // cacheDir defaults to <workDir>/singularity — and since workDir now carries
            // a per-run id, every run would re-pull and re-convert the large image.
            cacheDir    = "${params.out_root_oscer}/apptainer_cache"
            // The OCI→SIF conversion of this image on scratch is slow; the 20m
            // default pullTimeout gets killed (exit 143) mid-conversion.
            pullTimeout = '2h'
        }
    }
}

// Execution timeline written to the results directory
timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
}

// Detailed resource usage report written to the results directory
report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/report.html"
}

manifest {
    name        = 'sammy_r21'
    description = 'Nextflow pipeline for scRNA-seq analysis of the Sammy R21 cohort (normal vs obese)'
    version     = '0.1.0'
    nextflowVersion = '>=25.10.0'
}
